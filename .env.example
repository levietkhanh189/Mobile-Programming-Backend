NODE_ENV=development
PORT=3000
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=5
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_WINDOW_MINUTES=15

# Gmail SMTP (for sending OTP emails)
# Create an App Password at: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SePay payment gateway (sandbox for development)
SEPAY_MERCHANT_ID=SP-TEST-XXXXXXXX
SEPAY_SECRET_KEY=spsk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEPAY_ENV=sandbox
# Fixed exchange rate USD -> VND used when creating SePay checkout (sandbox only)
USD_TO_VND_RATE=25000
# Public base URL for webhook + success/error/cancel redirects (Railway prod, or ngrok URL for local test)
PUBLIC_BASE_URL=https://backend-production-9c18.up.railway.app
